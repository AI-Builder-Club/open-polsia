# ── Core (required to run locally) ───────────────────────────────────────────
# Postgres for platform state. Matches the docker one-liner in the README.
DATABASE_URL=postgres://postgres:polsia@localhost:5433/polsia

# LLM. pi can also use your interactive Claude login instead of a key.
ANTHROPIC_API_KEY=

# Web search for the research/onboarding agents (default provider: Tavily).
TAVILY_API_KEY=

# ── Dashboard ────────────────────────────────────────────────────────────────
# If set, the dashboard/API is gated behind HTTP basic auth (user: polsia).
POLSIA_DASHBOARD_PASSWORD=
# Background worker runs by default. Set to "off" to disable (e.g. cost-frozen demos).
POLSIA_WORKER=on

# ── Sandbox ──────────────────────────────────────────────────────────────────
# "local-docker" (default) or "daytona" (cloud execution).
SANDBOX_PROVIDER=local-docker

# ── Cloud deploy (optional — only needed to ship built apps to live URLs) ─────
DAYTONA_API_KEY=
NEON_API_KEY=
RENDER_API_KEY=
RENDER_OWNER_ID=
# Used by the control plane to push app repos from the cloud (falls back to gh CLI locally).
GITHUB_TOKEN=
# Public URL of the control plane; built apps' analytics beacons + secret proxy resolve here.
POLSIA_BEACON_URL=
